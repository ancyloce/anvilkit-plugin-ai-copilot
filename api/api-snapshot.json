	"packageName": "@anvilkit/plugin-ai-copilot",
	"readme": [
		{
			"kind": "text",
			"text": "# @anvilkit/plugin-ai-copilot\n\nHeadless AI copilot for Anvilkit Studio. The plugin caches a per-session\n"
		},
		{
			"kind": "code",
			"text": "`AiGenerationContext`"
		},
		{
			"kind": "text",
			"text": " derived from the host's Puck config, calls a\nhost-supplied "
		},
		{
			"kind": "code",
			"text": "`generatePage(prompt, ctx)`"
		},
		{
			"kind": "text",
			"text": " function, validates the\nresponse with "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/validator`"
		},
		{
			"kind": "text",
			"text": ", and dispatches the result atomically\nvia "
		},
		{
			"kind": "code",
			"text": "`setData`"
		},
		{
			"kind": "text",
			"text": ".\n\n> **Status:** alpha. API may change before "
		},
		{
			"kind": "code",
			"text": "`1.0`"
		},
		{
			"kind": "text",
			"text": ".\n\n## Install\n\n"
		},
		{
			"kind": "code",
			"text": "```bash\npnpm add @anvilkit/plugin-ai-copilot @anvilkit/core react react-dom @puckeditor/core\n```"
		},
		{
			"kind": "text",
			"text": "\n\n## Quickstart\n\n"
		},
		{
			"kind": "code",
			"text": "```ts\nimport { Studio } from \"@anvilkit/core\";\nimport { createAiCopilotPlugin } from \"@anvilkit/plugin-ai-copilot\";\nimport { puckConfig } from \"./puck-config\";\n\nconst aiCopilot = createAiCopilotPlugin({\n  puckConfig,\n  generatePage: (prompt, ctx) =>\n    fetch(\"/api/ai/generate\", {\n      method: \"POST\",\n      body: JSON.stringify({ prompt, availableComponents: ctx.availableComponents }),\n    }).then((response) => response.json()),\n  timeoutMs: 30_000,\n});\n\n<Studio puckConfig={puckConfig} plugins={[aiCopilot]} />\n```"
		},
		{
			"kind": "text",
			"text": "\n\nFor CI and local demos, "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/plugin-ai-copilot/mock`"
		},
		{
			"kind": "text",
			"text": " also ships\n"
		},
		{
			"kind": "code",
			"text": "`createMockGeneratePage()`"
		},
		{
			"kind": "text",
			"text": " and deterministic fixtures that match the\ndemo component catalog.\n\n## Phase 3 references\n\nSee the [Phase 3 plan]("
		},
		{
			"kind": "relative-link",
			"text": "../../../docs/plans/phase-3-export-ai-pipeline-plan.md",
			"target": 3
		},
		{
			"kind": "text",
			"text": ")\n("
		},
		{
			"kind": "code",
			"text": "`M5 — @anvilkit/plugin-ai-copilot`"
		},
		{
			"kind": "text",
			"text": ") and the\n[architecture package catalog]("
		},
		{
			"kind": "relative-link",
			"text": "../../../docs/ai-context/anvilkit-architecture.md",
			"target": 4
		},
		{
			"kind": "text",
			"text": ")\n("
		},
		{
			"kind": "code",
			"text": "`§7 — @anvilkit/plugins [Stubs Exist]`"
		},
		{
			"kind": "text",
			"text": ") for the plugin boundary and\nPhase 3 AI generation flow.\n\n## Peer dependencies\n\n| Package | Version |\n| ------- | ------- |\n| "
		},
		{
			"kind": "code",
			"text": "`react`"
		},
		{
			"kind": "text",
			"text": " | "
		},
		{
			"kind": "code",
			"text": "`^18.2.0`"
		},
		{
			"kind": "text",
			"text": " |\n| "
		},
		{
			"kind": "code",
			"text": "`react-dom`"
		},
		{
			"kind": "text",
			"text": " | "
		},
		{
			"kind": "code",
			"text": "`^18.2.0`"
		},
		{
			"kind": "text",
			"text": " |\n| "
		},
		{
			"kind": "code",
			"text": "`@puckeditor/core`"
		},
		{
			"kind": "text",
			"text": " | "
		},
		{
			"kind": "code",
			"text": "`^0.19.0`"
		},
		{
			"kind": "text",
			"text": " |\n\n## Security model\n\n- The plugin **never sees credentials**. API keys, auth headers, and\n  endpoints belong to the host backend.\n- "
		},
		{
			"kind": "code",
			"text": "`generatePage`"
		},
		{
			"kind": "text",
			"text": " is invoked with exactly two arguments: "
		},
		{
			"kind": "code",
			"text": "`(prompt, ctx)`"
		},
		{
			"kind": "text",
			"text": ".\n- Every LLM response runs through "
		},
		{
			"kind": "code",
			"text": "`validateAiOutput`"
		},
		{
			"kind": "text",
			"text": " before being\n  dispatched.\n- The dispatch is atomic.\n\n## License\n\nMIT."
		}
	],
